# Travel Experience Engine - Environment Variables

# Google Gemini API Key for the Smart Assistant
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key for location data and routing
# Get it from: Google Cloud Console -> Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Port to run the FastAPI app (Cloud Run sets this automatically to 8080)
PORT=8000
